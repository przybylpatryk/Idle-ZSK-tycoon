<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_main">

    <LinearLayout
        style="@style/UpgradeHeader">

        <TextView
            style="@style/UpgradeHeaderTitle"
            android:text="Statystyki" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout style="@style/UpgradeCard">
                <LinearLayout style="@style/UpgradeCardHeader">
                    <View style="@style/UpgradeAccent" />
                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="Łączna liczba przewiezionych uczniów" />
                </LinearLayout>
                <TextView
                    android:id="@+id/total_transported"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="0" />
            </LinearLayout>

            <LinearLayout style="@style/UpgradeCard">
                <LinearLayout style="@style/UpgradeCardHeader">
                    <View style="@style/UpgradeAccent" />
                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="Posiadane linie kolejowe" />
                </LinearLayout>
                <TextView
                    android:id="@+id/lines_owned"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="1/3" />
            </LinearLayout>

            <LinearLayout style="@style/UpgradeCard">
                <LinearLayout style="@style/UpgradeCardHeader">
                    <View style="@style/UpgradeAccent" />
                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="Obecna ilość nauczycieli" />
                </LinearLayout>
                <TextView
                    android:id="@+id/teachers_collected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="0" />
            </LinearLayout>

            <LinearLayout style="@style/UpgradeCard">
                <LinearLayout style="@style/UpgradeCardHeader">
                    <View style="@style/UpgradeAccent" />
                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="Obejrzane reklamy" />
                </LinearLayout>
                <TextView
                    android:id="@+id/total_ads_watched"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="0" />
            </LinearLayout>

            <LinearLayout style="@style/UpgradeCard">
                <LinearLayout style="@style/UpgradeCardHeader">
                    <View style="@style/UpgradeAccent" />
                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="Kupione nowe linie" />
                </LinearLayout>
                <TextView
                    android:id="@+id/total_trains_bought"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="0" />
            </LinearLayout>

            <LinearLayout style="@style/UpgradeCard">
                <LinearLayout style="@style/UpgradeCardHeader">
                    <View style="@style/UpgradeAccent" />
                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="Ulepszenia (pojemność i prędkość)" />
                </LinearLayout>
                <TextView
                    android:id="@+id/total_upgrades_bought"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_text"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="0" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/back_btn"
            style="@style/MenuPrimaryButton"
            android:text="@string/btn_back"
            android:layout_width="match_parent" />
    </LinearLayout>
</LinearLayout>