<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            style="@style/HeaderCard"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        style="@style/HeaderLabel"
                        android:text="@string/header_label_school" />

                    <TextView
                        android:id="@+id/school_text"
                        style="@style/HeaderValue"
                        android:text="0" />

                    <TextView
                        style="@style/HeaderUnit"
                        android:text="@string/header_students_unit" />
                </LinearLayout>

                <View style="@style/DividerVertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        style="@style/HeaderLabel"
                        android:text="@string/header_label_teachers" />

                    <TextView
                        android:id="@+id/teacher_text"
                        style="@style/HeaderValue"
                        android:text="0" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/ad_button"
                style="@style/AdButton"
                android:text="+5 🎓" />
        </LinearLayout>

        <LinearLayout style="@style/WeatherCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/weather_emoji"
                    style="@style/WeatherEmoji"
                    android:text="🌤️" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/weather_description"
                        style="@style/WeatherDesc"
                        android:text="@string/weather_loading" />

                    <TextView
                        android:id="@+id/weather_multiplier"
                        style="@style/WeatherMultiplier"
                        android:text="@string/weather_multiplier_default" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout style="@style/TramCard">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="3">

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/avenida_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/avenida" />

                    <TextView
                        android:id="@+id/avenida_text"
                        style="@style/AvenidaValue"
                        android:text="0" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/tram_image"
                    android:layout_width="0dp"
                    android:layout_weight="1.5"
                    android:layout_height="80dp"
                    android:src="@drawable/clip_tram_standard"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/school_icon"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    android:layout_height="48dp"
                    android:src="@drawable/zsk"
                    android:scaleType="fitCenter" />
            </LinearLayout>

            <TextView
                android:id="@+id/tram_status"
                style="@style/StatusText"
                android:text="@string/tram_status_waiting" />

            <Button
                android:id="@+id/tram_upgrade_btn"
                style="@style/CardButton"
                android:text="@string/tram_btn_upgrades" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/train1_card"
            style="@style/TrainCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    style="@style/TrainTitle"
                    android:text="@string/train_line_1_title" />

                <View style="@style/Spacer" />

                <Button
                    android:id="@+id/train1_upgrade_btn"
                    style="@style/CardButton"
                    android:text="@string/train_btn_upgrades" />
            </LinearLayout>

            <ImageView
                android:id="@+id/train1_image"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:src="@drawable/clip_train_standard"
                android:scaleType="fitStart" />

            <TextView
                android:id="@+id/train_status1"
                style="@style/StatusText"
                android:text="@string/train_status_waiting" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/train2_card"
            style="@style/TrainCard"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    style="@style/TrainTitle"
                    android:text="@string/train_line_2_title" />

                <View style="@style/Spacer" />

                <Button
                    android:id="@+id/train2_upgrade_btn"
                    style="@style/CardButton"
                    android:text="@string/train_btn_upgrades" />
            </LinearLayout>

            <ImageView
                android:id="@+id/train2_image"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:src="@drawable/clip_train_standard"
                android:scaleType="fitStart" />

            <TextView
                android:id="@+id/train_status2"
                style="@style/StatusText"
                android:text="@string/train_line_locked" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/train3_card"
            style="@style/TrainCard"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    style="@style/TrainTitle"
                    android:text="@string/train_line_3_title" />

                <View style="@style/Spacer" />

                <Button
                    android:id="@+id/train3_upgrade_btn"
                    style="@style/CardButton"
                    android:text="@string/train_btn_upgrades" />
            </LinearLayout>

            <ImageView
                android:id="@+id/train3_image"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:src="@drawable/clip_train_standard"
                android:scaleType="fitStart" />

            <TextView
                android:id="@+id/train_status3"
                style="@style/StatusText"
                android:text="@string/train_line_locked" />
        </LinearLayout>

        <Button
            android:id="@+id/new_train_btn"
            style="@style/NewTrainButton"
            android:text="@string/btn_buy_new_line" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>