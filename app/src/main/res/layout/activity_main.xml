<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer">

    <LinearLayout
        style="@style/Header.Bar"
        android:orientation="horizontal">

        <LinearLayout
            style="@style/Header.StatCard"
            android:layout_marginEnd="8dp">

            <TextView
                style="@style/Header.StatCard.Label"
                android:text="@string/header_label_avenida" />

            <TextView
                android:id="@+id/avenida_text"
                style="@style/Header.StatCard.Value"
                android:text="0" />

            <TextView
                style="@style/Header.StatCard.Unit"
                android:text="@string/header_students_unit" />
        </LinearLayout>

        <LinearLayout
            style="@style/Header.StatCard">

            <TextView
                style="@style/Header.StatCard.Label"
                android:text="@string/header_label_school" />

            <TextView
                android:id="@+id/school_text"
                style="@style/Header.StatCard.Value"
                android:text="0" />

            <TextView
                android:id="@+id/teacher_text"
                style="@style/Header.Counter"
                android:text="Nauczyciele: 0" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                style="@style/Card.Section">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/tram_section_title" />

                    <Button
                        android:id="@+id/tram_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/tram_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/tram_image"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:src="@drawable/clip_tram"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tram_status"
                    style="@style/Card.StatusText"
                    android:text="@string/tram_status_waiting" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train1_card"
                style="@style/Card.Section">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent"
                        android:backgroundTint="@color/success" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/train_line_1_title" />

                    <Button
                        android:id="@+id/train1_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/train_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/train1_image"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:src="@drawable/clip_train"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/train_status1"
                    style="@style/Card.StatusText"
                    android:text="@string/train_status_waiting" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train2_card"
                style="@style/Card.Section"
                android:visibility="gone">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent"
                        android:backgroundTint="@color/success" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/train_line_2_title" />

                    <Button
                        android:id="@+id/train2_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/train_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/train2_image"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:src="@drawable/clip_train"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/train_status2"
                    style="@style/Card.StatusText"
                    android:text="@string/train_line_locked" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train3_card"
                style="@style/Card.Section"
                android:visibility="gone">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent"
                        android:backgroundTint="@color/success" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/train_line_3_title" />

                    <Button
                        android:id="@+id/train3_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/train_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/train3_image"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:src="@drawable/clip_train"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/train_status3"
                    style="@style/Card.StatusText"
                    android:text="@string/train_line_locked" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        style="@style/BottomBar">

        <Button
            android:id="@+id/new_train_btn"
            style="@style/Button.Primary.Standard"
            android:text="@string/btn_buy_new_line" />
    </LinearLayout>

</LinearLayout>