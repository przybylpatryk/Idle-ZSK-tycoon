<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer">

    <LinearLayout
        style="@style/Header.Bar"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                style="@style/Header.StatCard"
                android:layout_marginEnd="8dp">

                <TextView
                    style="@style/Header.StatCard.Label"
                    android:text="@string/header_label_avenida" />

                <TextView
                    android:id="@+id/avenida_text"
                    style="@style/Header.StatCard.Value"
                    android:text="0" />

                <TextView
                    style="@style/Header.StatCard.Unit"
                    android:text="@string/header_students_unit" />
            </LinearLayout>

            <LinearLayout
                style="@style/Header.StatCard">

                <TextView
                    style="@style/Header.StatCard.Label"
                    android:text="@string/header_label_school" />

                <TextView
                    android:id="@+id/school_text"
                    style="@style/Header.StatCard.Value"
                    android:text="0" />

                <TextView
                    style="@style/Header.StatCard.Unit"
                    android:text="@string/header_students_unit" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/teacher_text"
                style="@style/Header.Counter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nauczyciele: 0"
                android:textSize="14sp" />

            <Button
                android:id="@+id/ad_button"
                style="@style/Button.Primary.Small"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="+5 nauczycieli 📺" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                style="@style/Card.Section">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        style="@style/Card.SectionHeader.Accent" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="Pogoda w Poznaniu" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/weather_emoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="36sp"
                        android:layout_marginEnd="12dp"
                        android:text="🌤️" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/weather_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:text="Ładuje pogodę..." />

                        <TextView
                            android:id="@+id/weather_multiplier"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp"
                            android:text="Mnożnik: ×1.0" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                style="@style/Card.Section">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/tram_section_title" />

                    <Button
                        android:id="@+id/tram_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/tram_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/tram_image"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/clip_tram_standard"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="@string/tram_content_description" />

                <TextView
                    android:id="@+id/tram_status"
                    style="@style/Card.StatusText"
                    android:text="@string/tram_status_waiting" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train1_card"
                style="@style/Card.Section">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent"
                        android:backgroundTint="@color/success" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/train_line_1_title" />

                    <Button
                        android:id="@+id/train1_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/train_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/train1_image"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/clip_train_standard"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="@string/train_content_description" />

                <TextView
                    android:id="@+id/train_status1"
                    style="@style/Card.StatusText"
                    android:text="@string/train_status_waiting" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train2_card"
                style="@style/Card.Section"
                android:visibility="gone">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent"
                        android:backgroundTint="@color/success" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/train_line_2_title" />

                    <Button
                        android:id="@+id/train2_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/train_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/train2_image"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/clip_train_standard"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="@string/train_content_description" />

                <TextView
                    android:id="@+id/train_status2"
                    style="@style/Card.StatusText"
                    android:text="@string/train_line_locked" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train3_card"
                style="@style/Card.Section"
                android:visibility="gone">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent"
                        android:backgroundTint="@color/success" />

                    <TextView
                        style="@style/Card.SectionHeader.Title"
                        android:text="@string/train_line_3_title" />

                    <Button
                        android:id="@+id/train3_upgrade_btn"
                        style="@style/Button.Secondary.Card"
                        android:text="@string/train_btn_upgrades" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/train3_image"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/clip_train_standard"
                    android:scaleType="fitStart"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="@string/train_content_description" />

                <TextView
                    android:id="@+id/train_status3"
                    style="@style/Card.StatusText"
                    android:text="@string/train_line_locked" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        style="@style/BottomBar">

        <Button
            android:id="@+id/new_train_btn"
            style="@style/Button.Primary.Standard"
            android:text="@string/btn_buy_new_line" />
    </LinearLayout>

</LinearLayout>