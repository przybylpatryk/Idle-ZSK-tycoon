<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer">

    <LinearLayout
        style="@style/Header.Bar.WithBack">

        <Button
            android:id="@+id/back_btn"
            style="@style/Button.Back"
            android:text="@string/btn_back"
            android:contentDescription="@string/nav_back_content_description" />

        <TextView
            style="@style/Header.Title.Screen"
            android:text="@string/train_upgrades_title" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/school_count"
                style="@style/Header.Counter"
                android:text="0" />

            <TextView
                android:id="@+id/teacher_count"
                style="@style/Header.Counter"
                android:text="0" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/train1_wrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/train1_section"
                    layout="@layout/item_train_section" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train2_wrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <include
                    android:id="@+id/train2_section"
                    layout="@layout/item_train_section" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/train3_wrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <include
                    android:id="@+id/train3_section"
                    layout="@layout/item_train_section" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
