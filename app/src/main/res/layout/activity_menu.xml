<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_header"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logo"
            android:textSize="52sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZSK TYCOON"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.15"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zarządzaj siecią transportową"
            android:textSize="13sp"
            android:textColor="#BBDEFB"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btn_play"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  GRAJ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_primary"
            android:stateListAnimator="@null"
            android:letterSpacing="0.08" />

        <Button
            android:id="@+id/btn_tram_upgrade"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ulepszenia tramwaju"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:background="@drawable/btn_secondary"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp" />

        <Button
            android:id="@+id/btn_train_upgrade"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ulepszenia pociągów"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:background="@drawable/btn_secondary"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp" />

        <Button
            android:id="@+id/btn_exit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Wyjdź z gry"
            android:textSize="14sp"
            android:textColor="#90A4AE"
            android:background="@android:color/transparent"
            android:stateListAnimator="@null"
            android:layout_marginTop="20dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ZSK Tycoon v1.0"
        android:textSize="11sp"
        android:textColor="#B0BEC5"
        android:gravity="center"
        android:paddingBottom="16dp" />

</LinearLayout>
