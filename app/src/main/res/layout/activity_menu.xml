<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer">

    <LinearLayout
        style="@style/Header.Bar.Menu">

        <TextView
            style="@style/Header.Title.AppName"
            android:text="@string/app_name" />

        <TextView
            style="@style/Header.Title.Subtitle"
            android:text="@string/app_subtitle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btn_play"
            style="@style/Button.Primary.Large"
            android:text="@string/menu_btn_play" />

        <Button
            android:id="@+id/btn_tram_upgrade"
            style="@style/Button.Secondary.Large"
            android:text="@string/menu_btn_tram_upgrades" />

        <Button
            android:id="@+id/btn_train_upgrade"
            style="@style/Button.Secondary.Large"
            android:text="@string/menu_btn_train_upgrades" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/Button.Ghost"
            android:text="@string/menu_btn_exit" />
    </LinearLayout>

    <TextView
        style="@style/Footer.VersionText"
        android:text="@string/app_version" />

</LinearLayout>
