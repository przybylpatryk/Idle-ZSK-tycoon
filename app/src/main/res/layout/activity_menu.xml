<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_main">

    <LinearLayout
        style="@style/MenuHeader"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            style="@style/MenuAppName"
            android:text="@string/app_name" />

        <TextView
            style="@style/MenuSubtitle"
            android:text="@string/app_subtitle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingVertical="24dp">

        <Button
            android:id="@+id/btn_play"
            style="@style/MenuPrimaryButton"
            android:text="@string/menu_btn_play" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/MenuGhostButton"
            android:text="@string/menu_btn_exit" />
    </LinearLayout>

    <TextView
        style="@style/FooterVersion"
        android:text="@string/app_version" />
</LinearLayout>