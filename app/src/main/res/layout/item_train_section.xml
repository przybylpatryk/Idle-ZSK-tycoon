<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Card.Section">

    <LinearLayout
        style="@style/Card.SectionHeader.Row">

        <View
            style="@style/Card.SectionHeader.Accent"
            android:backgroundTint="@color/success" />

        <TextView
            style="@style/Upgrade.SectionTitle"
            android:text="@string/train_section_capacity_title" />
    </LinearLayout>

    <LinearLayout
        style="@style/Upgrade.ControlRow"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/train_cap_level"
            style="@style/Upgrade.LevelText"
            android:text="Poziom 1/5" />

        <TextView
            android:id="@+id/train_cap_cost"
            style="@style/Upgrade.CostText"
            android:text="50 uczniów" />

        <Button
            android:id="@+id/train_cap_btn"
            style="@style/Button.Primary.Upgrade"
            android:text="@string/btn_upgrade_capacity" />
    </LinearLayout>

    <LinearLayout
        style="@style/Card.SectionHeader.Row">

        <View
            style="@style/Card.SectionHeader.Accent"
            android:backgroundTint="@color/primary" />

        <TextView
            style="@style/Upgrade.SectionTitle"
            android:text="@string/train_section_speed_title" />
    </LinearLayout>

    <LinearLayout
        style="@style/Upgrade.ControlRow"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/train_spd_level"
            style="@style/Upgrade.LevelText"
            android:text="Poziom 1/5" />

        <TextView
            android:id="@+id/train_spd_cost"
            style="@style/Upgrade.CostText"
            android:text="50 uczniów" />

        <Button
            android:id="@+id/train_spd_btn"
            style="@style/Button.Primary.Upgrade"
            android:text="@string/btn_upgrade_speed" />
    </LinearLayout>

    <LinearLayout
        style="@style/Card.SectionHeader.Row"
        android:layout_marginBottom="10dp">

        <View
            style="@style/Card.SectionHeader.Accent" />

        <TextView
            style="@style/Upgrade.SectionTitle"
            android:text="@string/train_section_models_title" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/models_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
