<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ulepszenia"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_school_balance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Uczniowie w szkole: 0"
            android:textSize="16sp"
            android:textColor="#555555"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pociąg"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ładowność pociągu"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_train_capacity_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ładowność: 5 os."
                android:textColor="#555555"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_train_capacity_level"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Poziom: 0/5"
                    android:textColor="#777777" />

                <TextView
                    android:id="@+id/tv_train_capacity_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koszt: 20"
                    android:textColor="#E65100"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btn_upgrade_train_capacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ulepsz"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Częstotliwość pociągu"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_train_speed_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interwał: 8s"
                android:textColor="#555555"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_train_speed_level"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Poziom: 0/5"
                    android:textColor="#777777" />

                <TextView
                    android:id="@+id/tv_train_speed_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koszt: 30"
                    android:textColor="#E65100"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btn_upgrade_train_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ulepsz"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tramwaj"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ładowność tramwaju"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tram_capacity_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ładowność: 20 os."
                android:textColor="#555555"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_tram_capacity_level"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Poziom: 0/5"
                    android:textColor="#777777" />

                <TextView
                    android:id="@+id/tv_tram_capacity_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koszt: 15"
                    android:textColor="#E65100"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btn_upgrade_tram_capacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ulepsz"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Częstotliwość tramwaju"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tram_speed_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interwał: 5s"
                android:textColor="#555555"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_tram_speed_level"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Poziom: 0/5"
                    android:textColor="#777777" />

                <TextView
                    android:id="@+id/tv_tram_speed_cost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koszt: 25"
                    android:textColor="#E65100"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btn_upgrade_tram_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ulepsz"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Powrót do gry"
            android:backgroundTint="#546E7A"
            android:textColor="#FFFFFF"
            android:onClick="onBackPressed" />

    </LinearLayout>
</ScrollView>