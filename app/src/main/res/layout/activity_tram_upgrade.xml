<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_main">

    <LinearLayout
        style="@style/UpgradeHeader">

        <Button
            android:id="@+id/back_btn"
            style="@style/BackButton"
            android:text="@string/btn_back" />

        <TextView
            style="@style/UpgradeHeaderTitle"
            android:text="@string/tram_upgrades_title" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/school_count"
                style="@style/HeaderCounter"
                android:text="0" />

            <TextView
                android:id="@+id/teacher_count"
                style="@style/HeaderCounter"
                android:text="0" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                style="@style/UpgradeCard">

                <LinearLayout
                    style="@style/UpgradeCardHeader">

                    <View style="@style/UpgradeAccent" />

                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="@string/tram_upgrade_capacity_title" />
                </LinearLayout>

                <LinearLayout
                    style="@style/UpgradeControlRow">

                    <TextView
                        android:id="@+id/tram_cap_level"
                        style="@style/UpgradeLevelText"
                        android:text="Poziom 1/5" />

                    <TextView
                        android:id="@+id/tram_cap_cost"
                        style="@style/UpgradeCostText"
                        android:text="50 uczniów" />

                    <Button
                        android:id="@+id/tram_cap_btn"
                        style="@style/UpgradeActionButton"
                        android:text="@string/btn_upgrade_capacity" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                style="@style/UpgradeCard">

                <LinearLayout
                    style="@style/UpgradeCardHeader">

                    <View style="@style/UpgradeAccent" />

                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="@string/tram_upgrade_speed_title" />
                </LinearLayout>

                <LinearLayout
                    style="@style/UpgradeControlRow">

                    <TextView
                        android:id="@+id/tram_spd_level"
                        style="@style/UpgradeLevelText"
                        android:text="Poziom 1/5" />

                    <TextView
                        android:id="@+id/tram_spd_cost"
                        style="@style/UpgradeCostText"
                        android:text="50 uczniów" />

                    <Button
                        android:id="@+id/tram_spd_btn"
                        style="@style/UpgradeActionButton"
                        android:text="@string/btn_upgrade_speed" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                style="@style/UpgradeCard">

                <LinearLayout
                    style="@style/UpgradeCardHeader">

                    <View style="@style/UpgradeAccent" />

                    <TextView
                        style="@style/UpgradeSectionTitle"
                        android:text="@string/tram_upgrade_models_title" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/models_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>