<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingBottom="24dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/back_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:stateListAnimator="@null"
            android:padding="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ulepszenia tramwaju"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/school_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 uczniów"
                android:textSize="12sp"
                android:textColor="#BBDEFB" />

            <TextView
                android:id="@+id/teacher_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 naucz."
                android:textSize="12sp"
                android:textColor="#BBDEFB" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_section_accent"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pojemność"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Obrazek Ludzi"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tram_cap_level"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Poziom 1/5"
                        android:textSize="14sp"
                        android:textColor="#455A64" />

                    <TextView
                        android:id="@+id/tram_cap_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50 uczniów"
                        android:textSize="12sp"
                        android:textColor="#FF5722"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/tram_cap_btn"
                        android:layout_width="120dp"
                        android:layout_height="40dp"
                        android:text="Ulepsz ⬆"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/btn_primary"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_section_accent"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Prędkość"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="obrazek?"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tram_spd_level"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Poziom 1/5"
                        android:textSize="14sp"
                        android:textColor="#455A64" />

                    <TextView
                        android:id="@+id/tram_spd_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50 uczniów"
                        android:textSize="12sp"
                        android:textColor="#FF5722"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/tram_spd_btn"
                        android:layout_width="120dp"
                        android:layout_height="40dp"
                        android:text="Ulepsz ⚡"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/btn_primary"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_section_accent"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Modele tramwajów"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/models_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
