<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer">

    <LinearLayout
        style="@style/Header.Bar.WithBack">

        <Button
            android:id="@+id/back_btn"
            style="@style/Button.Back"
            android:text="@string/btn_back"
            android:contentDescription="@string/nav_back_content_description" />

        <TextView
            style="@style/Header.Title.Screen"
            android:text="@string/tram_upgrades_title" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/school_count"
                style="@style/Header.Counter"
                android:text="0" />

            <TextView
                android:id="@+id/teacher_count"
                style="@style/Header.Counter"
                android:text="0" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                style="@style/Card.Section">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent" />

                    <TextView
                        style="@style/Upgrade.SectionTitle"
                        android:text="@string/tram_upgrade_capacity_title" />
                </LinearLayout>

                <LinearLayout
                    style="@style/Upgrade.ControlRow">

                    <TextView
                        android:id="@+id/tram_cap_level"
                        style="@style/Upgrade.LevelText"
                        android:text="Poziom 1/5" />

                    <TextView
                        android:id="@+id/tram_cap_cost"
                        style="@style/Upgrade.CostText"
                        android:text="50 uczniów" />

                    <Button
                        android:id="@+id/tram_cap_btn"
                        style="@style/Button.Primary.Upgrade"
                        android:text="@string/btn_upgrade_capacity" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                style="@style/Card.Section">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent" />

                    <TextView
                        style="@style/Upgrade.SectionTitle"
                        android:text="@string/tram_upgrade_speed_title" />
                </LinearLayout>

                <LinearLayout
                    style="@style/Upgrade.ControlRow">

                    <TextView
                        android:id="@+id/tram_spd_level"
                        style="@style/Upgrade.LevelText"
                        android:text="Poziom 1/5" />

                    <TextView
                        android:id="@+id/tram_spd_cost"
                        style="@style/Upgrade.CostText"
                        android:text="50 uczniów" />

                    <Button
                        android:id="@+id/tram_spd_btn"
                        style="@style/Button.Primary.Upgrade"
                        android:text="@string/btn_upgrade_speed" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                style="@style/Card.Section.Last">

                <LinearLayout
                    style="@style/Card.SectionHeader.Row">

                    <View
                        style="@style/Card.SectionHeader.Accent" />

                    <TextView
                        style="@style/Upgrade.SectionTitle"
                        android:text="@string/tram_upgrade_models_title" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/models_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
