<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer"
    android:gravity="center_horizontal">

    <LinearLayout
        style="@style/Header.Bar"
        android:gravity="center">

        <TextView
            style="@style/Header.Title"
            android:text="Reklama" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            style="@style/Card.Section">

            <ImageView
                android:id="@+id/ad_image"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="fitCenter"
                android:contentDescription="Reklama"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/timer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pozostało: 10 s"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/claim_button"
                style="@style/Button.Primary.Large"
                android:text="Odbierz 5 nauczycieli"
                android:enabled="false" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
